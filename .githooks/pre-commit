#!/usr/bin/env bash
# .githooks/pre-commit — territory check (agent-agnostic、本地版)
#
# 對齊 .github/workflows/territory-lint.yml v2 的白名單規則。
# 在 commit 前擋下違規、不浪費 push + CI 一輪。
#
# 適用場景：
#   - Claude Code 在本機 commit
#   - Codex CLI 在本機 commit
#   - Kai 手動 commit
#
# 啟用方式（每個 clone 跑一次）：
#   git config core.hooksPath .githooks
#
# 跳過方式（緊急、留 audit trail）：
#   git commit --no-verify  # 不建議、territory-lint CI 還是會擋

set -e

# 取當前分支
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

# 非 codex/* 或 claude/* 分支 → 不擋（main、HEAD detached、實驗分支等）
if [[ "$BRANCH" != claude/* && "$BRANCH" != codex/* ]]; then
  exit 0
fi

# 取本次 commit 的 staged 檔（含 deletions，與 territory-lint.yml CI 對齊）
# 不加 --diff-filter；CI 用 `git diff --name-only` 無 filter、本地需一致
# 否則「刪對方領土的檔」會本地放行、push 後 CI fail（PR #397 Codex review 指出）
CHANGED=$(git diff --cached --name-only)

if [[ -z "$CHANGED" ]]; then
  exit 0
fi

# 白名單（對齊 .github/workflows/territory-lint.yml v2、必同步更新兩邊）
CLAUDE_OK='^(02-skill-factory/|\.claude/|CLAUDE\.md|CLAUDE\.local\.md|01-data-brain/|03-production-line/|07-changelog/|dashboard/|docs/|engine-manifest\.json|README\.md|HOME\.md|AGENTS\.md|\.githooks/|\.github/|00-control-center/|data/)'
CODEX_OK='^(scripts/|tests/|data/|docs/contracts/|docs/references/|engine-manifest\.json|\.github/|AGENTS\.md|\.githooks/)'

violations=""
if [[ "$BRANCH" == claude/* ]]; then
  ROLE="Claude"
  PATTERN="$CLAUDE_OK"
else
  ROLE="Codex"
  PATTERN="$CODEX_OK"
fi

while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  if ! [[ "$f" =~ $PATTERN ]]; then
    violations="${violations}  ❌ $f"$'\n'
  fi
done <<< "$CHANGED"

if [[ -n "$violations" ]]; then
  echo ""
  echo "❌ Territory violation ($ROLE branch '$BRANCH'):"
  echo ""
  printf "%s" "$violations"
  echo ""
  echo "解法："
  echo "  1. 把越界的檔案 unstage、交給對方代理處理"
  echo "  2. 或 commit 後在 PR body 寫 'territory override justified by: <原因>'（CI 會放行）"
  echo "  3. 或臨時 bypass：git commit --no-verify（但 GitHub CI 仍會擋）"
  echo ""
  echo "白名單來源：.github/workflows/territory-lint.yml + docs/contracts/agent-collaboration.md §9.3"
  exit 1
fi

exit 0
